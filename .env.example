# ─── Database (local MongoDB) ───────────────────────────────
MONGODB_URI="mongodb://127.0.0.1:27017"
MONGODB_DB="mindbridge"

# ─── NextAuth ───────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_RANDOM_32_BYTE_SECRET"

# ─── Server-side encryption pepper ──────────────────────────
# Mixed into PBKDF2 in addition to the per-user salt. Keep this OUT of the DB.
ENCRYPTION_PEPPER="REPLACE_WITH_RANDOM_32_BYTE_SECRET"

# ─── OpenRouter (OpenAI-compatible chat completions) ────────
# Key from https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-REPLACE_ME"
# Any model on https://openrouter.ai/models — e.g. openai/gpt-4o,
# anthropic/claude-3.5-sonnet, meta-llama/llama-3.1-70b-instruct
OPENROUTER_MODEL="openai/gpt-4o"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_SITE_URL="http://localhost:3000"

# ─── Google Calendar (service account, already configured) ──
GOOGLE_SERVICE_ACCOUNT_EMAIL="mindbridge@your-project.iam.gserviceaccount.com"
# Base64-encoded service account JSON private key
GOOGLE_SERVICE_ACCOUNT_KEY_B64="REPLACE_WITH_BASE64_PRIVATE_KEY"
GOOGLE_CALENDAR_ID="primary"

# ─── Telegram bot (front-end + crisis escalation) ──────────
# Token from @BotFather. Required to run `npm run bot`.
TELEGRAM_BOT_TOKEN="REPLACE_ME"
TELEGRAM_DEFAULT_CHAT_ID=""
# How long (seconds) the bot keeps a derived encryption key in memory after
# the user's last message before requiring /login again.
BOT_SESSION_TTL_SECONDS="900"

# ─── Standalone API (server/) ───────────────────────────────
JWT_SECRET="REPLACE_WITH_RANDOM_32_BYTE_SECRET"
CORS_ORIGIN="http://localhost:3001"   # comma-separated frontend origins
# Frontend build-time var pointing at the API:
NEXT_PUBLIC_API_URL="http://localhost:4000"
